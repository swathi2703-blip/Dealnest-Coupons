MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=dealnest
PORT=4000
FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
RAZORPAY_KEY_ID=rzp_test_or_rzp_live_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
APP_PAYMENT_PLATFORM_FEE_PERCENT=15
APP_PAYMENT_PAYOUT_AUTO_ENABLED=true
APP_PAYMENT_PAYOUT_SOURCE_ACCOUNT_NUMBER=your_razorpayx_source_account_number
